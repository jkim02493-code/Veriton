{
  "manifest_version": 3,
  "name": "Veriton",
  "version": "0.1.0",
  "description": "AI-powered academic research and writing assistant for Google Docs.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "clipboardRead",
    "clipboardWrite",
    "contextMenus",
    "identity",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://docs.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://veriton.onrender.com/*",
    "https://*.onrender.com/*",
    "https://*.supabase.co/*"
  ],
  "oauth2": {
    "client_id": "791076560067-j2nllerjfn5imf0qv04fq591lab558t2.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/documents.readonly"]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Veriton"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.js", "*.css", "*.html"],
      "matches": ["https://docs.google.com/*"]
    }
  ]
}
